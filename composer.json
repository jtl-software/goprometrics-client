{
  "name": "jtl/go-prometrics-client",
  "type": "jtl-library",
  "description": "PHP-Client to use the JTL GoPrometrics Service",
  "license": "MIT",
  "require": {
    "php": "^8.3 || ^8.4 || ^8.5",
    "ext-curl": "*",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.12.0",
    "jtl/php-generic-collection": "^1.0.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95.8",
    "phpstan/phpstan": "^2.2.2",
    "phpunit/phpunit": "^12.5.30",
    "rector/rector": "^2.4"
  },
  "autoload": {
    "psr-4": {
      "JTL\\GoPrometrics\\Client\\": "src/"
    }
  },
  "autoload-dev": {
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "infection/extension-installer": true
    }
  },
  "scripts": {
    "tests": [
      "composer phpcs",
      "composer phpstan",
      "composer phpunit"
    ],
    "phpunit": [
      "vendor/bin/phpunit"
    ],
    "phpstan": [
      "vendor/bin/phpstan"
    ],
    "phpcs": [
      "vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.dist.php"
    ],
    "phpcs-dry": [
      "vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.dist.php --dry-run"
    ],
    "rector": [
      "vendor/bin/rector"
    ],
    "rector-dry": [
      "vendor/bin/rector --dry-run"
    ]
  }
}
